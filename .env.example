# Swiggy Talk — copy to .env and fill in values
# REQUIRED for dev: ORDER_ENABLED=false (never enable until eval suite passes)

# --- Gemini (Phase 3+) ---
GEMINI_API_KEY=

# --- Swiggy OAuth 2.1 + PKCE ---
# Must match URI registered with Swiggy (http://localhost:8000/auth/callback allowed for dev)
SWIGGY_OAUTH_CLIENT_ID=
SWIGGY_OAUTH_CLIENT_SECRET=
SWIGGY_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
SWIGGY_ACCESS_TOKEN=
SWIGGY_TOKEN_EXPIRY=

# --- Swiggy Food API (HTTP JSON-RPC, NOT MCP protocol) ---
SWIGGY_FOOD_URL=https://mcp.swiggy.com/food
SWIGGY_OAUTH_BASE_URL=https://mcp.swiggy.com

# --- App ---
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug
LOG_DIR=logs
LOG_FILE_NAME=swiggy-talk.log
LOG_ERRORS_FILE_NAME=errors.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SESSION_TIMEOUT_MINUTES=30

# --- Order safety (DO NOT set true in dev/CI) ---
ORDER_ENABLED=false
EVAL_SUITE_PASSED=false
